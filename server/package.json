{
  "name": "cheng-yan-operation-server",
  "version": "1.1.3beta",
  "description": "成研运营项目管理系统后端服务",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/database/migrate.ts migrate",
    "migrate:status": "tsx src/database/migrate.ts status",
    "seed": "tsx src/database/seed.ts",
    "backup": "tsx src/database/backup.ts create",
    "backup:list": "tsx src/database/backup.ts list",
    "backup:restore": "tsx src/database/backup.ts restore"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
